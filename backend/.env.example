# Скопируйте в .env и подставьте свои значения. Не коммитьте .env с реальными секретами.

# Путь к YAML (по умолчанию configs/local.yaml относительно рабочей директории процесса).
# CONFIG_PATH=configs/local.yaml

# HTTP
HTTP_PORT=8080

# Postgres (для docker-compose см. значения в deployments/docker-compose.yml)
POSTGRES_DSN=postgres://messenger:messenger@localhost:5432/messenger?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379

# JWT (каркас: значения загружаются в конфиг; выдача токенов — позже)
JWT_SECRET=local-dev-only-change-in-prod-min-16
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# Rate limits (requests per minute, per client IP; пустое значение в YAML → дефолты в коде)
# RATE_LIMIT_LOGIN_PER_MINUTE=60
# RATE_LIMIT_REGISTER_PER_MINUTE=20
# RATE_LIMIT_MESSAGE_SEND_PER_MINUTE=120
# RATE_LIMIT_WS_CONNECT_PER_MINUTE=30

# Для docker-compose (образ postgres)
POSTGRES_USER=messenger
POSTGRES_PASSWORD=messenger
POSTGRES_DB=messenger

# Применять SQL-миграции при старте процесса (см. migration.Up в cmd/app)
# RUN_MIGRATIONS_ON_STARTUP=true

# Kafka (outbox relay → broker; consumer → WS fan-out). В docker-compose по умолчанию включено.
# KAFKA_ENABLED=false
# KAFKA_BROKERS=localhost:9092
# KAFKA_TOPIC=goflow.domain.events
# KAFKA_CONSUMER_GROUP=goflow-ws-fanout

# WebSocket: allowlist Origin (через запятую), TTL тикета в configs/local.yaml (ws.ticket_ttl_seconds)
# WS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Логи (structured JSON для Loki / Alloy): см. configs/local.yaml → observability
# SERVICE_NAME=goflow-backend
# APP_ENV=development
# LOG_FORMAT=json

# Grafana в docker-compose (порт хоста и админ)
# GRAFANA_PORT=3001
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=admin
# GRAFANA_ROOT_URL=http://localhost:3001
