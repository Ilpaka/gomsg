{
  "title": "GoFlow Logs Overview",
  "uid": "goflow-logs",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "type": "logs",
      "title": "Recent backend container logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{container_name=~\".*app.*\"} |= ``",
          "refId": "A",
          "queryType": "range"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Error-level lines (JSON logs: level=ERROR)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 14 },
      "id": 2,
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{container_name=~\".*app.*\"} |~ \"(?i)error|panic\"",
          "refId": "A",
          "queryType": "range"
        }
      ]
    }
  ]
}
